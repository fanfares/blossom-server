{
  "name": "@hzrd149/blossom-server",
  "version": "6.1.5",
  "exports": "./main.ts",
  "license": "MIT",
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "@hono/hono/jsx",
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "tasks": {
    "dev": "deno run --env-file=.env --watch --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys --allow-run main.ts",
    "start": "deno run --env-file=.env --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys --allow-run main.ts",
    "test": "deno test --env-file=.env --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys tests/unit/ tests/e2e/",
    "build": "deno bundle --config src/landing/client/deno.json --minify --platform browser -o public/client.js src/landing/client/index.tsx",
    "reindex:metadata": "deno run --env-file=.env --allow-net --allow-read --allow-write --allow-env scripts/reindex-storage-metadata.ts",
    "d1:init": "wrangler d1 execute blossom-metadata --file scripts/d1/schema.sql --config wrangler.jsonc",
    "d1:init:remote": "wrangler d1 execute blossom-metadata --file scripts/d1/schema.sql --remote --config wrangler.jsonc",
    "d1:query": "wrangler d1 execute blossom-metadata --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\" --config wrangler.jsonc",
    "d1:query:remote": "wrangler d1 execute blossom-metadata --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\" --remote --config wrangler.jsonc"
  },
  "imports": {
    "@bradenmacdonald/s3-lite-client": "jsr:@bradenmacdonald/s3-lite-client@^0.9.5",
    "@hono/hono": "jsr:@hono/hono@^4.12.7",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/crypto": "jsr:@std/crypto@^1.0.5",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "applesauce-common": "npm:applesauce-common@^5.2.0",
    "applesauce-core": "npm:applesauce-core@^5.2.0",
    "applesauce-loaders": "npm:applesauce-loaders@^5.1.0",
    "applesauce-relay": "npm:applesauce-relay@^5.2.0",
    "rxjs": "npm:rxjs@^7.8.0",
    "nostr-tools": "npm:nostr-tools@^2.23.3",
    "@cashu/cashu-ts": "npm:@cashu/cashu-ts@^4.5.1",
    "sharp": "npm:sharp@^0.34.5",
    "file-type": "npm:file-type@^19.6.0",
    "zod": "npm:zod@^4.3.6"
  },
  "allowScripts": ["npm:sharp@0.34.5"],
  "exclude": ["src/landing/client"]
}
